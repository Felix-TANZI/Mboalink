server default {
    listen {
        type = auth
        ipaddr = *
        port = 1812
    }

    listen {
        type = acct
        ipaddr = *
        port = 1813
    }

    authorize {
        filter_username
        preprocess
        sql

        if (&control:Cleartext-Password) {
            update control {
                Auth-Type := PAP
            }
        }

        files
        expiration
        logintime
        pap
    }

    authenticate {
        Auth-Type PAP {
            pap
        }
        Auth-Type CHAP {
            chap
        }
    }

    preacct {
        preprocess
        acct_unique
        suffix
        files
    }

    accounting {
        detail
        sql
        exec
        attr_filter.accounting_response
    }

    session {
        sql
    }

    post-auth {
        sql
        exec
        remove_reply_message_if_eap

        Post-Auth-Type REJECT {
            attr_filter.access_reject
            sql
        }
    }

    pre-proxy {
    }

    post-proxy {
        eap
    }
}
